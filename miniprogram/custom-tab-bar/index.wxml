<view class="tab-bar {{isDarkMode ? 'dark' : ''}}"> 
  <view class="tab-bar-glass"></view> 
  <view 
    wx:for="{{list}}" 
    wx:key="index" 
    class="tab-bar-item {{selected === index ? 'active' : ''}}" 
    data-path="{{item.pagePath}}" 
    data-index="{{index}}" 
    bindtap="switchTab" 
  > 
    <text class="tab-text">{{item.text}}</text> 
  </view> 
</view>