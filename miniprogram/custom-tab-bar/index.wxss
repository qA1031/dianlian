.tab-bar { 
  position: absolute; 
  bottom: calc(16px + env(safe-area-inset-bottom, 0px)); 
  left: 24px; 
  right: 24px; 
  height: 80rpx; 
  background: var(--tabBarBg); 
  backdrop-filter: blur(28px) saturate(200%); 
  -webkit-backdrop-filter: blur(28px) saturate(200%); 
  border-radius: 50rpx; 
  border: 1px solid var(--cardBorder); 
  border-top-color: var(--cardBorder); 
  box-shadow: 0 12px 40px var(--shadowColor); 
  display: flex; 
  justify-content: space-around; 
  align-items: center; 
  padding: 0 16px; 
  overflow: hidden; 
  z-index: 9999; 
}

.tab-bar-glass { 
  position: absolute; 
  inset: 0; 
  background: transparent; 
  backdrop-filter: none; 
  -webkit-backdrop-filter: none; 
  border: none; 
  box-shadow: none; 
  z-index: 0; 
} 

.tab-bar-item { 
  position: relative; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  width: 52px; 
  height: 72rpx; 
  border-radius: 36rpx; 
  z-index: 1; 
  transition: all 0.2s ease-out; 
}

.tab-text { 
  font-size: 13px; 
  color: var(--textHint); 
  font-weight: 400; 
  transition: all 0.2s ease-out; 
} 

.tab-bar-item.active { 
  background: var(--activeBg); 
} 

.tab-bar-item.active .tab-text { 
  color: var(--primaryColor); 
  font-weight: 500; 
} 