<view class="container {{themeClass}}">
  <!-- 顶部统计 -->
  <view class="stats-header">
    <view class="stats-icon" style="background: linear-gradient(135deg, #e3f2fd, #bbdefb);">📋</view>
    <view class="stats-info">
      <text class="stats-value">{{submittedShopsCount}}</text>
      <text class="stats-label">已提交店铺</text>
    </view>
    <view class="add-btn" bindtap="goToSubmit">
      <text>+ 新增</text>
    </view>
  </view>

  <!-- 店铺列表 -->
  <block wx:if="{{shopList.length > 0}}">
    <view class="shop-list">
      <view class="shop-card" wx:for="{{shopList}}" wx:key="_id">
        <!-- 状态色条 -->
        <view class="card-accent" style="background: linear-gradient(90deg, {{item.statusColor}}, {{item.statusColorLight}});"></view>
        
        <view class="card-body">
          <!-- 头部信息 -->
          <view class="card-header">
            <view class="shop-meta">
              <text class="shop-name">{{item.shopName}}</text>
              <view class="shop-tags">
                <text class="type-tag" style="color: {{item.typeColor}}; background: {{item.typeBg}};">{{item.typeIcon}} {{item.shopType}}</text>
                <text class="location-tag">📍 {{item.addressName}}</text>
              </view>
            </view>
            <view class="status-badge" style="color: {{item.statusColor}}; background: {{item.statusBg}};">
              <text>{{item.statusIcon}} {{item.statusText}}</text>
            </view>
          </view>

          <!-- WiFi信息 -->
          <view class="wifi-panel">
            <view class="wifi-row">
              <text class="wifi-icon">📶</text>
              <text class="wifi-text">{{item.ssid}}</text>
            </view>
            <view class="wifi-row">
              <text class="wifi-icon">🔐</text>
              <text class="wifi-text password">{{item.hasPassword ? '••••••••' : '无密码'}}</text>
            </view>
          </view>

          <!-- 底部信息 -->
          <view class="card-footer">
            <view class="footer-left">
              <text class="view-count">👁️ {{item.viewCount}} 次查看</text>
              <text class="dot">·</text>
              <text class="date">{{item.createTimeStr}}</text>
            </view>
            <view class="footer-actions">
              <text class="action-btn edit" bindtap="editShop" data-id="{{item._id}}">编辑</text>
              <text class="action-btn delete" bindtap="deleteShop" data-id="{{item._id}}" data-index="{{index}}">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:else>
    <view class="empty-state">
      <view class="empty-icon">📋</view>
      <text class="empty-title">还没有提交过店铺</text>
      <text class="empty-desc">分享您知道的WiFi，帮助附近的人</text>
      <view class="empty-action" bindtap="goToSubmit">
        <text>+ 去提交第一个店铺</text>
      </view>
    </view>
  </block>
</view>