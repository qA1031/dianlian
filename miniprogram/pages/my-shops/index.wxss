/* pages/my-shops/index.wxss */
@import "../index/index.wxss"; /* 导入首页的通用样式 */

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.shop-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.shop-card {
  background: var(--cardBg);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: var(--shadowColor);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.2s ease;
}

.shop-card:active {
  transform: translateY(2rpx) scale(0.995);
  box-shadow: var(--shadowColor);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 0;
}

.shop-meta {
  flex: 1;
  min-width: 0;
}

.shop-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--textPrimary);
  line-height: 1.4;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
}

.shop-address {
  font-size: 28rpx;
  color: var(--textSecondary);
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.submit-time {
  font-size: 24rpx;
  color: var(--textHint);
}

.shop-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--textSecondary);
  flex-shrink: 0;
  margin-left: 16rpx;
  background: rgba(0,0,0,0.04); /* 与首页卡片图标背景保持一致 */
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 32rpx 28rpx; /* 内边距 */
  margin: 0 32rpx; /* 左右留白 */
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--cardBg); /* 卡片背景 */
  border-radius: 24rpx; /* 圆角 */
  box-shadow: var(--shadowColor); /* 弥散阴影 */
  border: none; /* 移除边框 */

  /* 垂直居中 */
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 64rpx); /* 减去左右留白 */
  box-sizing: border-box; /* 边框盒模型 */
}

.empty-icon {
  font-size: 64rpx; /* 图标尺寸 */
  color: var(--textSecondary); /* 图标颜色 */
  margin-bottom: 24rpx; /* 图标与标题间距 */
}

.empty-title {
  font-size: 36rpx; /* 标题字号 */
  font-weight: 600;
  color: var(--textPrimary);
  line-height: 1.4;
  margin-bottom: 16rpx; /* 标题与描述间距 */
}

.empty-desc {
  font-size: 28rpx; /* 描述字号 */
  color: var(--textSecondary);
  line-height: 1.5;
  margin-top: 12rpx;
  margin-bottom: 32rpx; /* 描述与按钮间距 */
}

.empty-action {
  display: inline-block;
  font-size: 30rpx; /* 行动按钮字号 */
  font-weight: 500;
  background: #07C160; /* 背景使用品牌色 */
  color: #fff;
  border-radius: 48rpx;
  padding: 18rpx 56rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx var(--shadowColor); /* 使用主题阴影变量 */
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.empty-action:active {
  transform: translateY(2rpx) scale(0.98);
  opacity: 0.9; /* 点击反馈 */
  box-shadow: none;
}