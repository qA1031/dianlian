/* pages/my-shops/my-shops.wxss */



.container {
  padding: 24rpx;
  background-color: var(--bgColor);
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 顶部统计 ===== */
.stats-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: var(--cardBg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadowColor);
}

.stats-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.stats-info {
  flex: 1;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--textPrimary);
  display: block;
}

.stats-label {
  font-size: 24rpx;
  color: var(--textHint);
  margin-top: 4rpx;
  display: block;
}

.add-btn {
  padding: 14rpx 32rpx;
  background: linear-gradient(135deg, var(--primaryColor), #05a050);
  color: var(--textPrimary);
  box-shadow: 0 4rpx 12rpx var(--primaryShadowColor);
}

/* ===== 店铺列表 ===== */
.shop-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 店铺卡片 ===== */
.shop-card {
  background: var(--cardBg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadowColor);
  overflow: hidden;
}

.card-accent {
  height: 6rpx;
  width: 100%;
}

.card-body {
  padding: 24rpx 24rpx 20rpx;
}

/* ===== 卡片头部 ===== */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.shop-meta {
  flex: 1;
  min-width: 0;
}

.shop-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--textPrimary);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 10rpx;
}

.shop-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.type-tag {
  font-size: 22rpx;
  padding: 3rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.location-tag {
  font-size: 22rpx;
  color: var(--textHint);
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== WiFi信息面板 ===== */
.wifi-panel {
  background: var(--bgColor);
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 16rpx;
}

.wifi-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.wifi-row:last-child {
  margin-bottom: 0;
}

.wifi-icon {
  font-size: 26rpx;
}

.wifi-text {
  font-size: 28rpx;
  color: var(--textSecondary);
  font-weight: 500;
}

.wifi-text.password {
  font-family: monospace;
  letter-spacing: 2rpx;
}

/* ===== 卡片底部 ===== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.view-count, .date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.dot {
  font-size: 22rpx;
  color: var(--textHint);
}

.footer-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: var(--bgColor);
  color: var(--text-secondary);
}

.action-btn.delete {
  background: #fff2f0;
  color: var(--badgeBg);
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 40rpx;
}

.empty-action {
  display: inline-flex;
  padding: 24rpx 56rpx;
  background: linear-gradient(135deg, var(--primaryColor), #05a050);
  color: var(--textPrimary);
  box-shadow: 0 8rpx 24rpx var(--primaryShadowColor);
}