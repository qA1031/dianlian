/* pages/my/edit-profile/edit-profile.wxss */
page {
  background-color: var(--bgColor);
}

.container {
  padding: 24rpx;
}

.profile-card {
  background: var(--cardBg);
  border-radius: 24rpx;
  box-shadow: var(--shadowColor);
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid var(--cardBorder);
  margin-bottom: 16rpx;
}

.avatar-hint {
  font-size: 24rpx;
  color: var(--textHint);
}

.form-item {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--cardBorder);
  margin-bottom: 32rpx;
}

.form-item:last-of-type {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: var(--textPrimary);
  width: 120rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: var(--textPrimary);
  padding-left: 20rpx;
}

.save-button {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #05a050);
  color: var(--textPrimary);
  box-shadow: 0 8rpx 24rpx var(--primaryShadowColor);
  transition: all 0.2s ease;
}

.save-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx var(--primaryShadowColor);
}