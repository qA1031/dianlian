/* app.wxss - 全局样式 */

page {
  --bgColor: #f5f5f5;
  --cardBg: rgba(255, 255, 255, 0.85);
  --textPrimary: #1a1a1a;
  --textSecondary: #666666;
  --textHint: #999999;
  --shadowColor: rgba(0, 0, 0, 0.08);
  --cardBorder: rgba(255, 255, 255, 0.3);
  --tabBarBg: rgba(255, 255, 255, 0.75);
  --inputBg: rgba(255, 255, 255, 0.6);
  /* 品牌色 */
  --primaryColor: #07C160;
  --hotColor: #ff9800;
  --hotBg: rgba(255, 152, 0, 0.1);
  --newColor: #2196F3;
  --newBg: rgba(33, 150, 243, 0.1);
  --skeletonBaseColor: #f6f7f8;
  --skeletonHighlightColor: #edeef1;
  --activeBg: rgba(0, 0, 0, 0.05);
  --primaryShadowColor: rgba(7, 193, 96, 0.35);
  --primaryBgLight: rgba(7, 193, 96, 0.1);
  --badgeBg: #ff4d4f;
  --badgeColor: #ffffff;
}

/* 通用文字层级样式 */
.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--textPrimary);
  line-height: 1.4;
}

.desc-text {
  font-size: 28rpx;
  color: var(--textSecondary);
  line-height: 1.5;
  margin-top: 12rpx;
}

/* 通用行动按钮样式 */
.action-button {
  font-size: 30rpx;
  font-weight: 500;
  background: var(--primaryColor);
  color: #fff;
  border-radius: 48rpx;
  padding: 18rpx 56rpx;
  border: none;
  display: inline-flex; /* 确保可以设置内边距和宽度 */
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.action-button:active {
  opacity: 0.8;
}

.dark {
  --bgColor: #1a1a1a;
  --cardBg: rgba(40, 40, 40, 0.88);
  --textPrimary: #f5f5f5;
  --textSecondary: #aaaaaa;
  --textHint: #777777;
  --shadowColor: rgba(0, 0, 0, 0.4);
  --cardBorder: rgba(255, 255, 255, 0.08);
  --tabBarBg: rgba(30, 30, 30, 0.8);
  --inputBg: rgba(255, 255, 255, 0.08);
  /* 品牌色保持不变 */
  --primaryColor: #07C160;
  --hotColor: #ff9800;
  --hotBg: rgba(255, 152, 0, 0.2);
  --newColor: #2196F3;
  --newBg: rgba(33, 150, 243, 0.2);
  --skeletonBaseColor: #2e2e2e;
  --skeletonHighlightColor: #4a4a4a;
  --activeBg: rgba(255, 255, 255, 0.08);
  --primaryShadowColor: rgba(7, 193, 96, 0.45);
  --primaryBgLight: rgba(7, 193, 96, 0.2);
  --badgeBg: #e04b4b;
  --badgeColor: #ffffff;
}